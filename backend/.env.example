### Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/tenun_geza"

### Server
PORT=3000
NODE_ENV=production

### Security
# Generate a long random secret for production
JWT_SECRET="CHANGE_ME_LONG_RANDOM_STRING"

# CORS allowed origins (comma-separated). Use "*" only for local dev.
ALLOWED_ORIGINS="https://your-frontend-domain.com"

# Request body size limit for JSON payloads
JSON_BODY_LIMIT="1mb"

# Rate limits
OTP_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_MAX=20

# Upload limits
UPLOAD_MAX_BYTES=5242880

# Public base URL used to build /uploads links behind reverse proxy
# Example: https://api.yourdomain.com
PUBLIC_BASE_URL="http://localhost:3000"

### Payment Gateway
# Pilih gateway yang aktif: "tripay" atau "midtrans"
ACTIVE_PAYMENT_GATEWAY="tripay"

### Midtrans (simpan sebagai cadangan)
MIDTRANS_SERVER_KEY="YOUR_MIDTRANS_SERVER_KEY"
MIDTRANS_CLIENT_KEY="YOUR_MIDTRANS_CLIENT_KEY"
MIDTRANS_IS_PRODUCTION=false

### TriPay
# Daftar & ambil credentials di: https://tripay.co.id/member/detail/merchant
TRIPAY_MERCHANT_CODE="YOUR_TRIPAY_MERCHANT_CODE"
TRIPAY_API_KEY="YOUR_TRIPAY_API_KEY"
TRIPAY_PRIVATE_KEY="YOUR_TRIPAY_PRIVATE_KEY"
TRIPAY_IS_PRODUCTION=false

### Email (Gmail SMTP)
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password"

